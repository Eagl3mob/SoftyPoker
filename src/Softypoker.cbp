<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="Softypoker" />
		<Option pch_mode="2" />
		<Option compiler="gcc" />
		<Build>
			<Target title="Debug">
				<Option output="../bin/Debug/Softypoker" prefix_auto="1" extension_auto="1" />
				<Option working_dir="$(PROJECT_DIR)" />
				<Option object_output="obj/Debug/" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-g" />
					<Add option="-std=c++17" />
					<Add directory="../../../SFML2/include" />
					<Add directory="../include" />
				</Compiler>
				<Linker>
					<Add library="sfml-audio-d" />
					<Add library="sfml-graphics-d" />
					<Add library="sfml-network-d" />
					<Add library="sfml-system-d" />
					<Add library="sfml-window-d" />
					<Add directory="../../../SFML2/lib" />
				</Linker>
			</Target>
			<Target title="Release">
				<Option output="../bin/Release/Softypoker" prefix_auto="1" extension_auto="1" />
				<Option working_dir="$(PROJECT_DIR)" />
				<Option object_output="obj/Release/" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-O2" />
					<Add option="-std=c++17" />
					<Add directory="../../../SFML2/include" />
					<Add directory="../include" />
				</Compiler>
				<Linker>
					<Add option="-s" />
					<Add library="sfml-audio" />
					<Add library="sfml-graphics" />
					<Add library="sfml-network" />
					<Add library="sfml-system" />
					<Add library="sfml-window" />
					<Add directory="../../../SFML2/lib" />
				</Linker>
			</Target>
		</Build>
		<Compiler>
			<Add option="-Wall" />
			<Add option="-fexceptions" />
			<Add option="-std=c++17" />
			<Add directory="../../../SFML2/include" />
			<Add directory="../include" />
		</Compiler>
		<Linker>
			<Add directory="../../../SFML2/lib" />
		</Linker>
		<Unit filename="Softypoker.cbp" />
		<Unit filename="SoundManager.cpp" />
		<Unit filename="main.cpp" />
		<Extensions>
			<lib_finder disable_auto="1" />
		</Extensions>
	</Project>
</CodeBlocks_project_file>
